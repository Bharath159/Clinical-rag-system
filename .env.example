# OpenAI Configuration (for OpenAI provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama Configuration (for local LLM provider)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# HuggingFace Configuration (for HuggingFace Inference API)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Note: You only need to configure the provider you plan to use
# Extractive provider requires no API keys
